	"item": [
		{
			"name": "Get Images",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Arrange: log the action and prepare variables if needed",
							"console.log('Arrange: Requesting the list of user-uploaded images');"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Assert: Verify status code is 200",
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"// Assert: Validate JSON Schema of the response",
							"pm.test('Response matches the Image List schema', function () {",
							"    const responseJson = pm.response.json();",
							"    const schema = {",
							"        type: 'array',",
							"        items: {",
							"            type: 'object',",
							"            required: ['id', 'url'],",
							"            properties: {",
							"                id: { type: 'string' },",
							"                url: { type: 'string' },",
							"                width: { type: 'number' },",
							"                height: { type: 'number' }",
							"            }",
							"        }",
							"    };",
							"    pm.expect(tv4.validate(responseJson, schema), tv4.error).to.be.true;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/images",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"images"
					]
				}
			},
			"response": []
		},
		{
			"name": "Post Image",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Arrange: Provide a URL for the image instead of a local file",
							"const imageUrl = 'https://cdn2.thedogapi.com/images/HkNS9lq47_1280.jpg';",
							"pm.collectionVariables.set('tempImageUrl', imageUrl);",
							"console.log('Arrange: Using URL for upload:', imageUrl);"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Assert: Verify status code is 201 (Created)",
							"pm.test('Status code is 201', function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"// Assert: Validate JSON Schema for upload response",
							"pm.test('Upload response matches schema', function () {",
							"    const responseJson = pm.response.json();",
							"    const schema = {",
							"        type: 'object',",
							"        required: ['id', 'url'],",
							"        properties: {",
							"            id: { type: 'string' },",
							"            url: { type: 'string' }",
							"        }",
							"    };",
							"    pm.expect(tv4.validate(responseJson, schema), tv4.error).to.be.true;",
							"});",
							"",
							"// Assert: Save imageId for subsequent requests",
							"const response = pm.response.json();",
							"pm.collectionVariables.set('imageId', response.id);",
							"console.log('Assert: Saved imageId for next steps:', response.id);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"url\": \"{{tempImageUrl}}\",\n    \"sub_id\": \"test-user-gh-actions\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/images/upload",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"images",
						"upload"
					]
				}
			},
			"response": []
