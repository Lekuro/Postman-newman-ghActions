    {
      "name": "/breeds",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"save rrandom breed\", function () {\r",
              "    const responseJson = pm.response.json();\r",
              "    const randomBreed = responseJson[Math.floor(Math.random() * responseJson.length)];\r",
              "    console.log(randomBreed);\r",
              "    pm.expect(randomBreed.id).to.be.not.null;\r",
              "    pm.expect(randomBreed.name).to.be.not.null;\r",
              "    pm.collectionVariables.set(\"breedId\", randomBreed.id);\r",
              "    pm.collectionVariables.set(\"breedObject\", JSON.stringify(randomBreed));\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
