    {
      "name": "/images-verify",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"breed is updated correctly\", function () {\r",
              "    const responseJson = pm.response.json();\r",
              "    const savedBreed = JSON.parse(pm.collectionVariables.get(\"breedObject\"));\r",
              "    const breed = responseJson[0].breeds.find(x => x.id = savedBreed.id);\r",
              "    console.log(responseJson[0].breeds)\r",
              "    pm.expect(breed).to.not.null;\r",
              "    pm.expect(breed.name).to.equal(savedBreed.name);\r",
              "\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
