		{
			"name": "Get Breeds",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Arrange: Log start",
							"console.log('Arrange: Retrieving list of dog breeds');"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Assert: Status code 200",
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"// Assert: Validate JSON Schema",
							"pm.test('Breeds list matches schema', function () {",
							"    const responseJson = pm.response.json();",
							"    const schema = {",
							"        type: 'array',",
							"        items: {",
							"            type: 'object',",
							"            required: ['id', 'name']",
							"        }",
							"    };",
							"    pm.expect(tv4.validate(responseJson, schema), tv4.error).to.be.true;",
							"});",
							"",
							"// Assert: Select a random breed and save it",
							"const breeds = pm.response.json();",
							"const randomBreed = breeds[Math.floor(Math.random() * breeds.length)];",
							"pm.collectionVariables.set('breedId', randomBreed.id);",
							"pm.collectionVariables.set('breedName', randomBreed.name);",
							"console.log('Assert: Selected breed:', randomBreed.name);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/breeds",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"breeds"
					]
				}
			},
			"response": []
		},
		{
			"name": "Post Breed To Image",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Arrange: Verify pre-requisites",
							"const imageId = pm.collectionVariables.get('imageId');",
							"const breedId = pm.collectionVariables.get('breedId');",
							"if (!imageId || !breedId) {",
							"    throw new Error('Arrange failed: imageId or breedId not found in collection variables');",
							"}",
							"console.log('Arrange: Associating breed ' + breedId + ' with image ' + imageId);"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Assert: Status code 200 or 201",
							"pm.test('Status code is 200 or 201', function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
							"});",
							"",
							"// Assert: Validate Schema",
							"pm.test('Response matches schema', function () {",
							"    const responseJson = pm.response.json();",
							"    const schema = {",
							"        type: 'object',",
							"        properties: {",
							"            message: { type: 'string' }",
							"        }",
							"    };",
							"    pm.expect(tv4.validate(responseJson, schema), tv4.error).to.be.true;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"breed_id\": {{breedId}}\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/images/{{imageId}}/breeds",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"images",
						"{{imageId}}",
						"breeds"
					]
				}
			},
			"response": []
		},
		{
			"name": "Get Image Breed",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Arrange: log action",
							"console.log('Arrange: Verifying the breed associated with the image');"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Assert: Status code 200",
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"// Assert: Verify data consistency",
							"pm.test('The image has the correct breed assigned', function () {",
							"    const images = pm.response.json();",
							"    const myImageId = pm.collectionVariables.get('imageId');",
							"    const myBreedName = pm.collectionVariables.get('breedName');",
							"    ",
							"    const foundImage = images.find(img => img.id === myImageId);",
							"    pm.expect(foundImage, 'Uploaded image not found in the list').to.not.be.undefined;",
							"    ",
							"    const hasBreed = foundImage.breeds.some(b => b.name === myBreedName);",
							"    pm.expect(hasBreed, 'Assigned breed not found in image metadata').to.be.true;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/images",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"images"
					]
				}
			},
			"response": []
		}
